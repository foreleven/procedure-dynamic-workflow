{
  "name": "pac",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/foreleven/procedure-dynamic-workflow.git"
  },
  "bugs": {
    "url": "https://github.com/foreleven/procedure-dynamic-workflow/issues"
  },
  "homepage": "https://github.com/foreleven/procedure-dynamic-workflow#readme",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "toolchain:check": "node scripts/verify-toolchain.mjs",
    "clean": "npm run clean -w @pac/workflow && npm run clean -w @pac/engine",
    "check": "tsc -p tsconfig.json --noEmit",
    "source:check": "node scripts/verify-source-hygiene.mjs",
    "build": "npm run build -w @pac/workflow && npm run build -w @pac/engine",
    "test:unit": "tsx --test packages/workflow/src/*.unit.test.ts packages/engine/src/*.unit.test.ts",
    "test": "npm run build && npm run test:unit",
    "cli:check": "node scripts/verify-cli-smoke.mjs",
    "smoke:packages": "npm run build && node scripts/verify-package-exports.mjs",
    "smoke:types": "npm run build && node scripts/verify-package-types.mjs",
    "smoke:tarballs": "node scripts/verify-package-tarballs.mjs",
    "smoke:install": "node scripts/verify-package-install.mjs",
    "metadata:check": "node scripts/verify-package-metadata.mjs",
    "publish:lifecycle:check": "node scripts/verify-publish-lifecycle.mjs",
    "publish:check": "node scripts/verify-publish-ready.mjs",
    "audit:check": "npm audit --audit-level=high",
    "docs:check": "node scripts/verify-doc-links.mjs && node scripts/verify-api-docs.mjs",
    "ci": "npm run toolchain:check && npm run check && npm run source:check && npm run build && npm run test:unit && npm run cli:check && node scripts/verify-package-exports.mjs && node scripts/verify-package-types.mjs && node scripts/verify-package-tarballs.mjs && npm run smoke:install && npm run metadata:check && npm run publish:lifecycle:check && npm run audit:check && npm run docs:check && npm run scenario:maintenance:check",
    "chat": "tsx packages/engine/src/cli.ts",
    "chat:maintenance": "tsx packages/engine/src/cli.ts --workflow scenarios/maintenance/maintenance_booking.workflow.ts --connectors scenarios/maintenance/connectors.ts --user-id user_feng",
    "scenario:maintenance:check": "tsx scripts/verify-maintenance-scenario.ts",
    "scenario:maintenance": "tsx scenarios/maintenance/run.ts",
    "test:llm": "tsx packages/engine/src/typebox-tool.manual.ts"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "dotenv": "^17.4.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
