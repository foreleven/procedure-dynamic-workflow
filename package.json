{
  "name": "pac",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/foreleven/procedure-dynamic-workflow.git"
  },
  "bugs": {
    "url": "https://github.com/foreleven/procedure-dynamic-workflow/issues"
  },
  "homepage": "https://github.com/foreleven/procedure-dynamic-workflow#readme",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "npm run clean -w @pac/workflow && npm run clean -w @pac/engine",
    "check": "tsc -p tsconfig.json --noEmit",
    "build": "npm run build -w @pac/workflow && npm run build -w @pac/engine",
    "test:unit": "tsx --test \"packages/*/src/**/*.unit.test.ts\"",
    "test": "npm run check && npm run build && npm run test:unit",
    "pack:check": "npm run build && npm pack --workspace @pac/workflow --dry-run --ignore-scripts && npm pack --workspace @pac/engine --dry-run --ignore-scripts",
    "audit:check": "npm audit --audit-level=high",
    "ci": "npm test && npm run audit:check",
    "chat": "tsx packages/engine/src/cli.ts",
    "chat:maintenance": "tsx packages/engine/src/cli.ts agents/maintenance --user-id user_feng",
    "test:llm": "tsx packages/engine/src/typebox-tool.manual.ts"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "dotenv": "^17.4.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
