# OpenAI-compatible provider credentials for local CLI and manual LLM smoke tests.
OPENAI_API_KEY=
OPENAI_MODEL=

# Optional. Example: https://api.openai.com/v1
OPENAI_BASE_URL=

# Investment advisor MCP connector runtime configuration.
# Required for `make chat investment-advisor` and `npm run scenario:investment-advisor`.
PAC_INVESTMENT_ADVISOR_MCP_URL=
PAC_INVESTMENT_ADVISOR_MCP_AUTHORIZATION=

# Optional JSON object for additional MCP headers, for example {"X-Custom":"value"}.
PAC_INVESTMENT_ADVISOR_MCP_HEADERS_JSON=

# Tavily connector runtime configuration for agents/open-web-intelligence.
# Either TAVILY_API_KEY or PAC_TAVILY_API_KEY can be used.
TAVILY_API_KEY=
PAC_TAVILY_API_KEY=

# Optional. Override Tavily API base URL, for example https://api.tavily.com.
TAVILY_BASE_URL=

# Optional. Tavily project tracking header.
TAVILY_PROJECT_ID=
